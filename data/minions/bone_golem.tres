[resource]
script = ExtResource("1_minion")
id = "bone_golem"
name = "Bone Golem"
icon = ExtResource("3_icon")
sort_order = 7
description = "Not raised — assembled. Thirty spare skeletons' worth of scaffolding around a tungsten-bound core, hammered together at the Boneyard Forge. It moves like a rockslide with a schedule."
base_hp = 45
base_atk = 3.0
hp_per_level = 8
atk_per_level = 0.6
speed = 0.6
raise_cost = Dictionary[String, int]({
"golem_core": 1
})
abilities = Array[ExtResource("2_ability")]([SubResource("Ability0"), SubResource("Ability1"), SubResource("Ability2"), SubResource("Ability3"), SubResource("Ability4"), SubResource("Ability5"), SubResource("Ability6"), SubResource("Ability7"), SubResource("Ability8")])
