[resource]
script = ExtResource("1_minion")
id = "homunculus"
name = "Homunculus"
icon = ExtResource("3_icon")
sort_order = 5
description = "Not raised — made. A small, precise person grown in the Caretaker's vat, still smelling faintly of the Still. The only minion on the grounds that was never buried, and the proof that Alchemy's Great Work can be finished."
base_hp = 30
base_atk = 3.5
hp_per_level = 6
atk_per_level = 0.8
speed = 1.1
raise_cost = Dictionary[String, int]({
"homunculus_heart": 1
})
abilities = Array[ExtResource("2_ability")]([SubResource("Ability0"), SubResource("Ability1"), SubResource("Ability2"), SubResource("Ability3"), SubResource("Ability4"), SubResource("Ability5"), SubResource("Ability6"), SubResource("Ability7"), SubResource("Ability8")])
