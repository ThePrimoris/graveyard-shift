[resource]
script = ExtResource("1_recipe")
id = "brew_the_quickening"
name = "The Quickening"
description = "Wyrm-scale for armor, nightshade for dreams, cobalt for a temper. The Seed becomes a heart; the heart wants a body. The Great Work concludes at the Ritual Altar."
inputs = {"seed_of_flesh": 1, "obsidian_wyrm_scale": 1, "nightshade_vine": 3, "cobalt_powder": 3}
output_item = ExtResource("2_out")
required_level = 85
base_seconds = 300.0
base_xp = 1000.0
