[resource]
script = ExtResource("1_recipe")
id = "smith_golem_chassis"
name = "The Golem Work: Chassis"
description = "Pin a giant's worth of bone to a granite spine with tungsten rivets. The first of the Golem Work: a body, waiting for a reason."
inputs = {"bones": 30, "cracked_skull": 6, "tungsten_lump": 10, "granite_cobble": 12}
output_item = ExtResource("2_out")
required_level = 35
base_seconds = 120.0
base_xp = 400.0
metadata/_custom_type_script = "res://data/RecipeData.gd"
