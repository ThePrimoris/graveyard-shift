[ext_resource type="Resource" path="res://data/items/materials/golem_core.tres" id="2_out"]

[resource]
script = ExtResource("1_recipe")
id = "smith_golem_core"
name = "The Golem Work: Core"
description = "Strike the lattice's keystone vertebra until it hums with borrowed purpose. The last of the Golem Work — carry it to the Ritual Altar and give the bones something to gather around."
inputs = {"animus_lattice": 1, "resonant_geode": 2, "obsidian_shard": 12, "cobalt_powder": 10}
output_item = ExtResource("2_out")
required_level = 75
base_seconds = 180.0
base_xp = 1200.0
metadata/_custom_type_script = "res://data/RecipeData.gd"
