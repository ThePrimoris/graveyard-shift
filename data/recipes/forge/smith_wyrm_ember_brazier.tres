[resource]
script = ExtResource("1_recipe")
id = "smith_wyrm_ember_brazier"
name = "Wyrm-Ember Brazier"
description = "Fold obsidian shards around a wyrm scale and feed the coal within something it can hate."
inputs = {"obsidian_wyrm_scale": 1, "obsidian_shard": 8, "cinder_slag": 4}
