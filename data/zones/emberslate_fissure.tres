[resource]
script = ExtResource("1_zone")
id = "emberslate_fissure"
name = "Emberslate Fissure"
description = "A hot fissure that hisses with building gas as you strike it."
required_level = 10
nodes = Array[ExtResource("2_hnode")]([ExtResource("3_n1"), ExtResource("3_n2"), ExtResource("3_n3"), ExtResource("dungeon_node")])
