[gd_resource type="Resource" script_class="HarvestZone" format=3]

[ext_resource type="Script" path="res://data/ZoneData.gd" id="1_zone"]
[ext_resource type="Script" path="res://data/HarvestNodeData.gd" id="2_hnode"]
[ext_resource type="Resource" path="res://data/nodes/mines/crag_granite.tres" id="3_n1"]
[ext_resource type="Resource" path="res://data/nodes/mines/tungsten_seam.tres" id="3_n2"]
[ext_resource type="Resource" path="res://data/nodes/mines/beryl_pocket.tres" id="3_n3"]

[resource]
script = ExtResource("1_zone")
id = "hollow_crag"
name = "Hollow Crag"
description = "A vast hollow where every pick-fall rings back a hundredfold."
required_level = 20
nodes = Array[ExtResource("2_hnode")]([ExtResource("3_n1"), ExtResource("3_n2"), ExtResource("3_n3")])
