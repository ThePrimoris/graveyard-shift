[resource]
script = ExtResource("1_zone")
id = "shrouded_ashwoods"
name = "Shrouded Ashwoods"
description = "Mist-choked ashwoods where the sap runs thick and slow."
required_level = 20
nodes = Array[ExtResource("2_hnode")]([ExtResource("3_n1"), ExtResource("3_n2"), ExtResource("3_n3")])
