[gd_resource type="Resource" script_class="HarvestZone" format=3]

[ext_resource type="Script" path="res://data/ZoneData.gd" id="1_zone"]
[ext_resource type="Script" path="res://data/HarvestNodeData.gd" id="2_hnode"]
[ext_resource type="Resource" path="res://data/nodes/trees/blackthorn_stand.tres" id="3_n1"]
[ext_resource type="Resource" path="res://data/nodes/trees/thorn_brambles.tres" id="3_n2"]
[ext_resource type="Resource" path="res://data/nodes/trees/briar_hollow.tres" id="3_n3"]
[ext_resource type="Resource" path="res://data/nodes/trees/bramblewake.tres" id="dungeon_node"]

[resource]
script = ExtResource("1_zone")
id = "thornwood_grove"
name = "Thornwood Grove"
description = "A tangle of black, barbed trees that lean inward as you work."
required_level = 10
nodes = Array[ExtResource("2_hnode")]([ExtResource("3_n1"), ExtResource("3_n2"), ExtResource("3_n3"), ExtResource("dungeon_node")])
