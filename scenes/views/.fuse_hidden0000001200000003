const COL_CARD := Color("#1a1530")
const COL_ENEMY_CARD := Color("#1a1226")
const COL_EDGE := Color("#3a2f52")
const COL_ENEMY_EDGE := Color("#6d3a3a")
const COL_TEXT_HI := Color("#e8e2d4")
const COL_TEXT_MID := Color("#c9c2b4")
const COL_TEXT_LOW := Color("#9a90a8")
const COL_TEXT_GHOST := Color("#5a5470")
const COL_TEXT_FAINT := Color("#6f6582")
const COL_GOLD := Color("#c8a24d")
const COL_RUST := Color("#c25a4a")
const COL_RUST_TEXT := Color("#e8c2b8")
const COL_GREEN := Color("#4c9a47")
const COL_VIOLET := Color("#8a6fbe")
const COL_VIOLET_TEXT := Color("#c9c4dd")
const COL_CHARGE := Color("#7a6538")
const COL_WELL := Color("#0c0a18")

# Bottom cluster geometry, used to line the promoted card up with the
# plots bar's central circle (true screen center). The view's content sits
# right of screen center by half the sidebar margins: (264 - 16) / 2.
const CONTENT_CENTER_BIAS := 124.0
const MENU_W := 158.0
const ACTIVE_W := 300.0
const SQUAD_W := 252.0
const CLUSTER_SEP := 10.0

# Engine tuning
const TURN_SECONDS := 2.4          ## Seconds for a speed-1.0 gauge to fill
const BEAT_SECONDS := 0.75         ## Pause after every action: the scene
								   ## holds on the log line, input is dead,
								   ## and spam clicks fall on deaf ears
const DMG_VARIANCE := 0.15         ## Attacks roll ATK ± this fraction
const ACTIVE_RUNE_MULT := 1.6      ## Active runes hit this much harder
const GUARD_REDUCTION := 0.5       ## Guarding halves incoming damage
const BOSS_SLAM_MULT := 0.75       ## The telegraphed slam's per-target ATK share
const BOSS_SLAM_CHANCE := 0.3      ## Odds the boss telegraphs a slam next

## A foe: { "name", "glyph", "hp", "max_hp", "atk", "speed", "charge",
##   "rage", "is_boss", "slam_name", "telegraph", "segments_broken",
##   "xp", "gold_min", "gold_max", "loot_pool" }
var enemies: Array = []
var is_boss_fight: bool = false
## A warband member: { "minion_id", "hp", "max_hp", "charge", "speed", "guarding" }
var party: Array = []
## minion_id -> Array of active ability ids already spent this fight.
var used_actives: Dictionary = {}

var fight_state: String = "idle"   # idle | active | victory | defeat
var waiting_for_command: bool = false
## Seconds left in the current action beat (see BEAT_SECONDS).
var action_beat: float = 0.0
var target_index: int = 0
var acting_index: int = 0
var auto_mode: bool = false
var paused: bool = true

var auto_button: Button
var pause_label: Label
var enemy_holder: VBoxContainer
var log_label: Label
var hint_label: Label
var command_holder: VBoxContainer
var party_row: HBoxContainer
## Charge-bar fill panels updated per frame without rebuilding (index-aligned
## with `party`; null when that member's bar isn't on screen).
var charge_fills: Array = []
## Same, for enemy turn gauges (index-aligned with `enemies`).
var enemy_charge_fills: Array = []
## The last promoted member, so a change of actor fades in instead of snapping.
var _last_promoted: int = -1

func _ready() -> void:
	add_to_group(Ids.Group.COMBAT_VIEWS)
	_apply_ambience()
	_build_shell()

## Same page-tint treatment as the harvest views, in battle-dark violet.
func _apply_ambience() -> void:
	var style := StyleBoxFlat.new()
	style.bg_color = COL_PAGE
	var previous := get_theme_stylebox("panel")
	if previous:
		style.content_margin_left = previous.content_margin_left
		style.content_margin_top = previous.content_margin_top
		style.content_margin_right = previous.content_margin_right
		style.content_margin_bottom = previous.content_margin_bottom
	add_theme_stylebox_override("panel", style)

# =====================================================================
# THE ENGINE
# =====================================================================

func _process(delta: float) -> void:
	if fight_state != "active" or not visible:
		return
	_update_charge_fills()
	# The action beat: the scene holds a moment after every action so the
	# player can read what happened before the next thing moves.
	if action_beat > 0.0:
		action_beat -= delta
		if action_beat <= 0.0:
			_refresh_hint()
		return
	# Wait mode: time freezes while a minion awaits your command.
	if waiting_for_command and not auto_mode:
		return

	# Tick every living combatant's gauge; whoever crests first acts.
	var ready_party := -1
	var ready_enemy := -1
	for i in range(party.size()):
		var member = party[i]
		if member["hp"] <= 0: continue
		member["charge"] = minf(member["charge"] + delta * member["speed"] / TURN_SECONDS, 1.0)
		if member["charge"] >= 1.0 and ready_party == -1:
			ready_party = i
	for i in range(enemies.size()):
		var foe = enemies[i]
		if foe["hp"] <= 0: continue
		foe["charge"] = minf(foe["charge"] + delta * foe["speed"] / TURN_SECONDS, 1.0)
		if foe["charge"] >= 1.0 and ready_enemy == -1:
			ready_enemy = i

	# One action per frame keeps the log readable.
	if ready_enemy != -1:
		_enemy_act(ready_enemy)
	elif ready_party != -1:
		if auto_mode:
			_execute_attack(ready_party, _default_target(), 1.0, "")
		else:
			waiting_for_command = true
			acting_index = ready_party
			_refresh_all()

## The current target if it still stands, else the first living foe.
func _default_target() -> int:
	if target_index < enemies.size() and enemies[target_index]["hp"] > 0:
		return target_index
	for i in range(enemies.size()):
		if enemies[i]["hp"] > 0:
			return i
	return -1

func _roll_damage(base: float, mult: float = 1.0) -> int:
	return maxi(1, int(round(base * mult * randf_range(1.0 - DMG_VARIANCE, 1.0 + DMG_VARIANCE))))

# --- Warband actions ---

func _execute_attack(member_idx: int, enemy_idx: int, mult: float, label: String) -> void:
	if fight_state != "active" or action_beat > 0.0: return
	if member_idx < 0 or member_idx >= party.size(): return
	if enemy_idx < 0 or enemy_idx >= enemies.size(): return
	var member = party[member_idx]
	var foe = enemies[enemy_idx]
	if member["hp"] <= 0 or foe["hp"] <= 0: return

	var minion = MinionManager.find_minion_by_id(member["minion_id"])
	var dmg = _roll_damage(MinionManager.get_atk(minion.id), mult)
	foe["hp"] = maxi(foe["hp"] - dmg, 0)

	var verb = label if label != "" else "strikes"
	if foe["hp"] <= 0:
		_log("%s %s %s for %d — it falls!" % [minion.name, verb, foe["name"], dmg])
	else:
		_log("%s %s %s for %d." % [minion.name, verb, foe["name"], dmg])

	_check_boss_enrage(foe)
	member["charge"] = 0.0
	member["guarding"] = false
	waiting_for_command = false
	acting_index = member_idx
	if _all_enemies_down():
		_enter_victory()
	else:
		action_beat = BEAT_SECONDS
		_refresh_all()

func _execute_guard(member_idx: int) -> void:
	if fight_state != "active" or action_beat > 0.0: return
	var member = party[member_idx]
	if member["hp"] <= 0: return
	member["guarding"] = true
	member["charge"] = 0.0
	waiting_for_command = false
	var minion = MinionManager.find_minion_by_id(member["minion_id"])
	_log("%s braces behind its own bones." % minion.name)
	action_beat = BEAT_SECONDS
	_refresh_all()

func _execute_active(member_idx: int, ability: MinionAbility) -> void:
	if fight_state != "active": return
	var member = party[member_idx]
	var minion_id: String = member["minion_id"]
	if _active_used(minion_id, ability.id): return
	if not used_actives.has(minion_id):
		used_actives[minion_id] = []
	used_actives[minion_id].append(ability.id)
	_execute_attack(member_idx, _default_target(), ACTIVE_RUNE_MULT, "unleashes %s on" % ability.name)

func _active_used(minion_id: String, ability_id: String) -> bool:
	return used_actives.has(minion_id) and used_actives[minion_id].has(ability_id)

func _flee() -> void:
	fight_state = "idle"
	_log("The warband withdraws.")
	get_tree().call_group(Ids.Group.VIEW_MANAGER, "switch_view", Ids.View.GRAVEYARD)

# --- Enemy actions ---

func _enemy_act(enemy_idx: int) -> void:
	var foe = enemies[enemy_idx]
	foe["charge"] = 0.0

	if foe["is_boss"] and foe["telegraph"] != "":
		# The telegraphed slam: everyone standing takes a share.
		foe["telegraph"] = ""
		var hits: Array = []
		for member in party:
			if member["hp"] <= 0: continue
			var dmg = _apply_party_damage(member, foe["atk"] * foe["rage"] * BOSS_SLAM_MULT)
			hits.append(str(dmg))
		_log("%s! The whole warband takes %s." % [foe["slam_name"], " / ".join(hits)])
	else:
		var living: Array = []
		for i in range(party.size()):
			if party[i]["hp"] > 0:
				living.append(i)
		if living.is_empty():
			_enter_defeat()
			return
		var victim_idx: int = living[randi() % living.size()]
		var member = party[victim_idx]
		var minion = MinionManager.find_minion_by_id(member["minion_id"])
		var dmg = _apply_party_damage(member, foe["atk"] * foe["rage"])
		if member["hp"] <= 0:
			_log("%s savages %s for %d — it collapses!" % [foe["name"], minion.name, dmg])
		else:
			_log("%s claws %s for %d%s." % [foe["name"], minion.name, dmg,
				" (guarded)" if member["guarding"] else ""])

	# Bosses declare their next move; the banner shows slam warnings.
	if foe["is_boss"] and foe["slam_name"] != "":
		foe["telegraph"] = foe["slam_name"] if randf() < BOSS_SLAM_CHANCE else ""

	if _all_party_down():
		_enter_defeat()
	else:
		action_beat = BEAT_SECONDS
		_refresh_all()

## Applies damage to a member (guard halves it). Returns the damage dealt.
func _apply_party_damage(member: Dictionary, base: float) -> int:
	var dmg = _roll_damage(base, GUARD_REDUCTION if member["guarding"] else 1.0)
	member["hp"] = maxi(member["hp"] - dmg, 0)
	return dmg

## Each broken quarter of a boss's health stokes its fury.
func _check_boss_enrage(foe: Dictionary) -> void:
	if not foe["is_boss"] or foe["hp"] <= 0: return
	var broken = clampi(int(floor((1.0 - float(foe["hp"]) / float(foe["max_hp"])) * 4.0)), 0, 3)
	if broken > foe["segments_broken"]:
		foe["rage"] += foe["enrage_per_segment"] * (broken - foe["segments_broken"])
		foe["segments_broken"] = broken
		if foe["enrage_per_segment"] > 0.0:
			_log("%s ENRAGES — its fury grows!" % foe["name"])

func _all_enemies_down() -> bool:
	for foe in enemies:
		if foe["hp"] > 0: return false
	return true

func _all_party_down() -> bool:
	for member in party:
		if member["hp"] > 0: return false
	return true

# --- Endings ---

func _enter_victory() -> void:
	fight_state = "victory"
	waiting_for_command = false

	var gold := 0
	var total_xp := 0.0
	for foe in enemies:
		gold += randi_range(foe["gold_min"], foe["gold_max"])
		total_xp += foe["xp"]
		var drop = GameManager.roll_chance_table(foe["loot_pool"])
		if drop:
			var amount = randi_range(drop.min_amount, maxi(drop.min_amount, drop.max_amount))
			InventoryManager.add_item(drop.item, amount)
			NotificationManager.show_item(drop.item.name, amount, drop.item)
	GameManager.gold_coins += gold

	var survivors: Array = []
	for member in party:
		if member["hp"] > 0:
			MinionManager.add_xp(member["minion_id"], total_xp)
			survivors.append(member["minion_id"])
	if gold > 0:
		NotificationManager.show_item("%d gold looted from the fallen" % gold, 1)

	_log("VICTORY — %d gold, %.0f XP to each survivor." % [gold, total_xp])
	get_tree().call_group(Ids.Group.UI_UPDATES, "update_ui")
	_refresh_all()

func _enter_defeat() -> void:
	fight_state = "defeat"
	waiting_for_command = false
	_log("The warband is broken. The dead will rise again — at home.")
	_refresh_all()

# =====================================================================
# ENCOUNTERS
# =====================================================================

## Starts a fight from an Encounter resource.
func start_encounter_res(encounter: Encounter) -> void:
	var foes: Array = []
	for enemy in encounter.enemies:
		if enemy != null:
			foes.append(enemy)
	_begin_fight(foes, encounter.is_boss_encounter())

## Console-launchable fights pulled from the encounter registry.
func start_test_encounter(boss: bool = false) -> void:
	var encounter = GameManager.find_encounter_by_id("old_crypt" if boss else "restless_dead")
	if encounter:
		start_encounter_res(encounter)

func _begin_fight(foes: Array, boss: bool) -> void:
	is_boss_fight = boss
	enemies.clear()
	for enemy in foes:
		enemies.append({
			"name": enemy.name,
			"glyph": enemy.glyph,
			"hp": enemy.base_hp,
			"max_hp": enemy.base_hp,
			"atk": enemy.atk,
			"speed": enemy.speed,
			"charge": randf_range(0.0, 0.4),
			"rage": 1.0,
			"is_boss": enemy.is_boss,
			"slam_name": enemy.telegraph_name,
			"telegraph": enemy.telegraph_name if enemy.is_boss and enemy.telegraph_name != "" and randf() < BOSS_SLAM_CHANCE else "",
			"enrage_per_segment": enemy.enrage_per_segment,
			"segments_broken": 0,
			"xp": enemy.xp_reward,
			"gold_min": enemy.gold_min,
			"gold_max": enemy.gold_max,
			"loot_pool": enemy.loot_pool,
		})

	party.clear()
	used_actives.clear()
	var ids: Array = []
	for minion_id in MinionManager.plots:
		if minion_id != "" and not ids.has(minion_id):
			ids.append(minion_id)
	if ids.is_empty():
		ids = MinionManager.sorted_ids(true)
	for minion_id in ids:
		var minion = MinionManager.find_minion_by_id(minion_id)
		party.append({
			"minion_id": minion_id,
			"hp": MinionManager.get_hp(minion_id),
			"max_hp": MinionManager.get_hp(minion_id),
			# Low starting charge so the gauges visibly fill before the
			# first turn — the mechanic teaches itself in the opening beat.
			"charge": randf_range(0.0, 0.35),
			"speed": minion.speed,
			"guarding": false,
		})

	target_index = 0
	# Promote whoever will reach a full gauge first, so the opening beat
	# shows the right minion instead of teleport-swapping seconds in.
	acting_index = 0
	var best_eta := INF
	for i in range(party.size()):
		var eta = (1.0 - party[i]["charge"]) / party[i]["speed"]
		if eta < best_eta:
			best_eta = eta
			acting_index = i
	_last_promoted = -1
	waiting_for_command = false
	action_beat = 0.0
	fight_state = "active" if not party.is_empty() else "idle"
	paused = not auto_mode
	_log("Your warband bares its teeth.")
	_refresh_all()

