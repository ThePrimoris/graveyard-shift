func _build_shell() -> void:
	var col = VBoxContainer.new()
	col.add_theme_constant_override("separation", 12)
	add_child(col)

	# Top right: AUTO toggle + pause state, floating free of any chrome
	var top = HBoxContainer.new()
	top.add_theme_constant_override("separation", 10)
	col.add_child(top)
	var top_spacer = Control.new()
	top_spacer.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	top.add_child(top_spacer)
	auto_button = Button.new()
	auto_button.toggle_mode = true
	auto_button.custom_minimum_size = Vector2(96, 28)
	auto_button.add_theme_font_size_override("font_size", 11)
	auto_button.toggled.connect(_on_auto_toggled)
	top.add_child(auto_button)
	pause_label = Label.new()
	pause_label.add_theme_font_size_override("font_size", 12)
	top.add_child(pause_label)
	_refresh_header_state()

	# Enemy area: rebuilt per encounter (card row, or the boss banner)
	enemy_holder = VBoxContainer.new()
	enemy_holder.add_theme_constant_override("separation", 8)
	col.add_child(enemy_holder)

	# Center: rolling log + prompt, floating between the lines of battle.
	# Wrapped with a counterweight so the text centers on the SCREEN's
	# middle (the circle button's line), not the sidebar-shifted content.
	var mid_spacer_a = Control.new()
	mid_spacer_a.size_flags_vertical = Control.SIZE_EXPAND_FILL
	col.add_child(mid_spacer_a)

	var center_wrap = HBoxContainer.new()
	col.add_child(center_wrap)

	var center_box = VBoxContainer.new()
	center_box.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	center_box.add_theme_constant_override("separation", 6)
	center_wrap.add_child(center_box)

	log_label = Label.new()
	log_label.text = "The dead assemble..."
	log_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	log_label.add_theme_font_size_override("font_size", 13)
	log_label.add_theme_color_override("font_color", COL_TEXT_FAINT)
	center_box.add_child(log_label)

	hint_label = Label.new()
	hint_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	hint_label.add_theme_font_size_override("font_size", 12)
	hint_label.add_theme_color_override("font_color", COL_TEXT_GHOST)
	center_box.add_child(hint_label)

	var center_counterweight = Control.new()
	center_counterweight.custom_minimum_size = Vector2(CONTENT_CENTER_BIAS * 2.0, 0)
	center_wrap.add_child(center_counterweight)

	var mid_spacer_b = Control.new()
	mid_spacer_b.size_flags_vertical = Control.SIZE_EXPAND_FILL
	col.add_child(mid_spacer_b)

	# Bottom: a condensed, centered cluster — command panel | promoted
	# card | squad panel — instead of stretching across the full width.
	var bottom = HBoxContainer.new()
	bottom.alignment = BoxContainer.ALIGNMENT_CENTER
	bottom.add_theme_constant_override("separation", 10)
	col.add_child(bottom)

	var command_panel = PanelContainer.new()
	command_panel.custom_minimum_size = Vector2(MENU_W, 0)
	var cstyle := StyleBoxFlat.new()
	cstyle.bg_color = COL_STRIP
	cstyle.set_border_width_all(1)
	cstyle.border_color = COL_EDGE
	cstyle.set_corner_radius_all(8)
	cstyle.content_margin_left = 12
	cstyle.content_margin_right = 12
	cstyle.content_margin_top = 9
	cstyle.content_margin_bottom = 9
	command_panel.add_theme_stylebox_override("panel", cstyle)
	bottom.add_child(command_panel)

	command_holder = VBoxContainer.new()
	command_holder.add_theme_constant_override("separation", 4)
	command_panel.add_child(command_holder)

	party_row = HBoxContainer.new()
	party_row.add_theme_constant_override("separation", 10)
	bottom.add_child(party_row)

# =====================================================================
# UI — refresh
# =====================================================================

func _refresh_all() -> void:
	paused = not auto_mode
	_refresh_header_state()
	_rebuild_enemy_area()
	_rebuild_command_panel()
	_rebuild_party_row()
	_refresh_hint()

func _refresh_header_state() -> void:
	if auto_button:
		auto_button.text = "AUTO: %s" % ("ON" if auto_mode else "OFF")
		auto_button.set_pressed_no_signal(auto_mode)
	if pause_label:
		if auto_mode:
			pause_label.text = "▶ running"
			pause_label.add_theme_color_override("font_color", COL_GREEN)
		else:
			pause_label.text = "❚❚ wait mode"
			pause_label.add_theme_color_override("font_color", COL_GOLD)

func _refresh_hint() -> void:
	match fight_state:
		"victory":
			hint_label.text = "The field is yours."
		"defeat":
			hint_label.text = "Retreat, regroup, return."
		_:
			if party.is_empty():
				hint_label.text = "No warband — raise minions in the Necronomicon and slot them into plots."
			elif auto_mode:
				hint_label.text = "The dead fight on their own. Toggle AUTO to take command."
			elif waiting_for_command:
				hint_label.text = "Time stops: %s's turn gauge is full. Pick a command." % _actor_name()
			else:
				hint_label.text = "Turn gauges fill — whoever fills first acts next…"

func _actor_name() -> String:
	if acting_index < 0 or acting_index >= party.size(): return "Nobody"
	var minion = MinionManager.find_minion_by_id(party[acting_index]["minion_id"])
	return minion.name if minion else "Nobody"

## Per-frame gauge updates that DON'T rebuild anything (tooltips survive).
func _update_charge_fills() -> void:
	for i in range(charge_fills.size()):
		if i >= party.size(): break
		var fill = charge_fills[i]
		if fill == null or not is_instance_valid(fill): continue
		var charge: float = party[i]["charge"]
		fill.anchor_right = clampf(charge, 0.0, 1.0)
		fill.visible = charge > 0.001
	for i in range(enemy_charge_fills.size()):
		if i >= enemies.size(): break
		var fill = enemy_charge_fills[i]
		if fill == null or not is_instance_valid(fill): continue
		var charge: float = enemies[i]["charge"]
		fill.anchor_right = clampf(charge, 0.0, 1.0)
		fill.visible = charge > 0.001

# --- Enemy area: card row, or the boss banner ---

func _rebuild_enemy_area() -> void:
	_clear(enemy_holder)
	enemy_charge_fills.clear()
	for i in range(enemies.size()):
		enemy_charge_fills.append(null)
	if enemies.is_empty(): return
	if is_boss_fight:
		enemy_holder.add_child(_make_boss_banner(enemies[0]))
	else:
		var row = HBoxContainer.new()
		row.alignment = BoxContainer.ALIGNMENT_CENTER
		row.add_theme_constant_override("separation", 18)
		enemy_holder.add_child(row)
		for i in range(enemies.size()):
			row.add_child(_make_enemy_card(i))
		# Counterweight: center the enemy line on the screen, not the content
		var counterweight = Control.new()
		counterweight.custom_minimum_size = Vector2(CONTENT_CENTER_BIAS * 2.0, 0)
		row.add_child(counterweight)

func _make_enemy_card(index: int) -> Button:
	var foe = enemies[index]
	var targeted = index == target_index
	var dead = foe["hp"] <= 0
	# A Button styled as a card. Buttons don't lay children out like
	# containers, so the content VBox is anchored full-rect with margins
	# and the button carries an explicit minimum size.
	var card = Button.new()
	card.custom_minimum_size = Vector2(200, 156)
	var style := StyleBoxFlat.new()
	style.bg_color = COL_ENEMY_CARD
	style.border_color = COL_GOLD if targeted and not dead else COL_ENEMY_EDGE
	style.set_border_width_all(2 if targeted and not dead else 1)
	style.set_corner_radius_all(8)
	var hover: StyleBoxFlat = style.duplicate()
	if not dead:
		hover.border_color = COL_GOLD
	card.add_theme_stylebox_override("normal", style)
	card.add_theme_stylebox_override("hover", hover)
	card.add_theme_stylebox_override("pressed", style)
	card.add_theme_stylebox_override("focus", StyleBoxEmpty.new())
	if dead:
		card.modulate.a = 0.35
	else:
		card.pressed.connect(func():
			target_index = index
			_rebuild_enemy_area()
			_refresh_hint())

	var col = VBoxContainer.new()
	col.set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT)
	col.offset_left = 14
	col.offset_top = 12
	col.offset_right = -14
	col.offset_bottom = -14
	col.alignment = BoxContainer.ALIGNMENT_CENTER
	col.add_theme_constant_override("separation", 8)
	col.mouse_filter = Control.MOUSE_FILTER_IGNORE
	card.add_child(col)

	var glyph = Label.new()
	glyph.text = foe["glyph"]
	glyph.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	glyph.add_theme_font_size_override("font_size", 42)
	glyph.add_theme_color_override("font_color", COL_RUST)
	col.add_child(glyph)

	var name_lbl = Label.new()
	name_lbl.text = foe["name"]
	name_lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	name_lbl.text_overrun_behavior = TextServer.OVERRUN_TRIM_ELLIPSIS
	name_lbl.add_theme_font_size_override("font_size", 14)
	name_lbl.add_theme_color_override("font_color", COL_TEXT_HI if targeted else COL_TEXT_MID)
	col.add_child(name_lbl)

	col.add_child(_make_bar(float(foe["hp"]) / float(foe["max_hp"]), COL_RUST, 8))

	# Its turn gauge — attacks stop coming from nowhere.
	if not dead:
		var turn_bar = _make_bar(foe["charge"], COL_CHARGE, 4)
		turn_bar.tooltip_text = "Turn gauge — when it fills, %s strikes." % foe["name"]
		enemy_charge_fills[index] = turn_bar.get_child(0)
		col.add_child(turn_bar)

	card.tooltip_text = "%s — %d / %d HP%s" % [foe["name"], foe["hp"], foe["max_hp"],
		"" if targeted or dead else ". Click to target."]
	return card

## The boss framing: wide banner, segmented health, telegraphed next move.
func _make_boss_banner(foe: Dictionary) -> PanelContainer:
	var banner = PanelContainer.new()
	var style := StyleBoxFlat.new()
	style.bg_color = COL_ENEMY_CARD
	style.set_border_width_all(1)
	style.border_color = COL_ENEMY_EDGE
	style.set_corner_radius_all(8)
	style.content_margin_left = 18
	style.content_margin_right = 18
	style.content_margin_top = 14
	style.content_margin_bottom = 14
	banner.add_theme_stylebox_override("panel", style)

	var col = VBoxContainer.new()
	col.add_theme_constant_override("separation", 9)
	banner.add_child(col)

	var top = HBoxContainer.new()
	col.add_child(top)
	var name_lbl = Label.new()
	name_lbl.text = "%s %s" % [foe["glyph"], foe["name"]]
	name_lbl.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	name_lbl.add_theme_font_size_override("font_size", 20)
	name_lbl.add_theme_color_override("font_color", COL_RUST_TEXT)
	top.add_child(name_lbl)
	var boss_tag = Label.new()
	boss_tag.text = "ENRAGED ×%.2f" % foe["rage"] if foe["rage"] > 1.0 else "BOSS"
	boss_tag.add_theme_font_size_override("font_size", 12)
	boss_tag.add_theme_color_override("font_color", COL_RUST)
	top.add_child(boss_tag)

	# Segmented health: four bars; each one broken enrages it.
	var segments = HBoxContainer.new()
	segments.add_theme_constant_override("separation", 3)
	col.add_child(segments)
	var seg_count := 4
	var health: float = float(foe["hp"]) / float(foe["max_hp"])
	for i in range(seg_count):
		# Damage eats the RIGHTMOST gauge first: segment i holds the
		# (i+1)-th quarter of health, so the last one drains first.
		var seg_fill = clampf(health * seg_count - i, 0.0, 1.0)
		var seg = _make_bar(seg_fill, COL_RUST, 16)
		seg.size_flags_horizontal = Control.SIZE_EXPAND_FILL
		segments.add_child(seg)

	var foot = HBoxContainer.new()
	col.add_child(foot)
	var hp_lbl = Label.new()
	hp_lbl.text = "%d / %d — each bar broken enrages it" % [foe["hp"], foe["max_hp"]]
	hp_lbl.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	hp_lbl.add_theme_font_size_override("font_size", 11)
	hp_lbl.add_theme_color_override("font_color", COL_TEXT_LOW)
	foot.add_child(hp_lbl)
	if foe["telegraph"] != "":
		var tele = Label.new()
		tele.text = "⚠ winding up: %s" % foe["telegraph"]
		tele.add_theme_font_size_override("font_size", 11)
		tele.add_theme_color_override("font_color", COL_GOLD)
		foot.add_child(tele)

	# The boss's own turn gauge: its next move is always visibly coming.
	var turn_row = HBoxContainer.new()
	turn_row.add_theme_constant_override("separation", 8)
	turn_row.tooltip_text = "Turn gauge — when it fills, the boss acts."
	col.add_child(turn_row)
	var turn_lbl = Label.new()
	turn_lbl.text = "NEXT MOVE"
	turn_lbl.add_theme_font_size_override("font_size", 9)
	turn_lbl.add_theme_color_override("font_color", COL_TEXT_GHOST)
	turn_row.add_child(turn_lbl)
	var turn_bar = _make_bar(foe["charge"], COL_CHARGE, 5)
	turn_bar.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	turn_bar.size_flags_vertical = Control.SIZE_SHRINK_CENTER
	enemy_charge_fills[0] = turn_bar.get_child(0)
	turn_row.add_child(turn_bar)
	return banner

# --- Bottom: the anchored command panel ---

func _rebuild_command_panel() -> void:
	_clear(command_holder)

	match fight_state:
		"victory":
			command_holder.add_child(_menu_header("VICTORY"))
			command_holder.add_child(_menu_row("Collect & Return", true, true, func():
				fight_state = "idle"
				get_tree().call_group(Ids.Group.VIEW_MANAGER, "switch_view", Ids.View.GRAVEYARD)))
		"defeat":
			command_holder.add_child(_menu_header("DEFEAT"))
			command_holder.add_child(_menu_row("Retreat", true, true, func():
				fight_state = "idle"
				get_tree().call_group(Ids.Group.VIEW_MANAGER, "switch_view", Ids.View.GRAVEYARD)))
		_:
			var can_command = waiting_for_command and not auto_mode
			command_holder.add_child(_menu_header("%s ACTS" % _actor_name().to_upper() if can_command else "AWAITING"))
			command_holder.add_child(_menu_row("Attack", true, can_command, func():
				_execute_attack(acting_index, _default_target(), 1.0, "")))
			command_holder.add_child(_menu_row("Guard", false, can_command, func():
				_execute_guard(acting_index)))
			command_holder.add_child(_menu_row("Flee", false, true, _flee))

func _menu_header(text: String) -> Label:
	var header = Label.new()
	header.text = text
	header.add_theme_font_size_override("font_size", 10)
	header.add_theme_color_override("font_color", COL_GOLD)
	return header

func _menu_row(text: String, selected: bool, enabled: bool, on_press: Callable) -> Button:
	var b = Button.new()
	b.text = ("▶ " if selected and enabled else "  ") + text
	b.flat = true
	b.disabled = not enabled
	b.alignment = HORIZONTAL_ALIGNMENT_LEFT
	b.add_theme_font_size_override("font_size", 13)
	b.add_theme_color_override("font_color", COL_GOLD if selected and enabled else COL_TEXT_LOW)
	b.add_theme_color_override("font_hover_color", COL_GOLD)
	b.add_theme_color_override("font_disabled_color", COL_TEXT_GHOST)
	b.add_theme_stylebox_override("focus", StyleBoxEmpty.new())
	if enabled:
		b.pressed.connect(on_press)
	return b

# --- Bottom: promoted actor beside the menu, the squad panel beside it ---

func _rebuild_party_row() -> void:
	_clear(party_row)
	charge_fills.clear()
	for i in range(party.size()):
		charge_fills.append(null)
	if party.is_empty():
		var empty = Label.new()
		empty.text = "The plots stand empty."
		empty.size_flags_horizontal = Control.SIZE_EXPAND_FILL
		empty.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		empty.add_theme_font_size_override("font_size", 12)
		empty.add_theme_color_override("font_color", COL_TEXT_GHOST)
		party_row.add_child(empty)
		return
	# The acting minion is promoted: a large detail card right of the menu.
	# A change of actor fades the new card in rather than hard-swapping.
	if acting_index >= 0 and acting_index < party.size():
		var promoted = _make_active_card(acting_index)
		party_row.add_child(promoted)
		if acting_index != _last_promoted:
			var settled_alpha = promoted.modulate.a
			promoted.modulate.a = 0.0
			var tween = create_tween()
			tween.tween_property(promoted, "modulate:a", settled_alpha, 0.35) \
				.set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_OUT)
		_last_promoted = acting_index
	# The rest of the squad lives in its own bordered panel, AB3-style:
	# compact name | HP bar | charge rows.
	var squad_shown = party.size() > 1
	if squad_shown:
		party_row.add_child(_make_squad_panel())

	# Counterweight spacer: slides the centered cluster left until the
	# promoted card sits on the screen's center line (the circle button).
	var cluster_w = MENU_W + CLUSTER_SEP + ACTIVE_W
	if squad_shown:
		cluster_w += CLUSTER_SEP + SQUAD_W
	var card_center = MENU_W + CLUSTER_SEP + ACTIVE_W * 0.5
	var shift = CONTENT_CENTER_BIAS + (card_center - cluster_w * 0.5)
	if shift > 0.0:
		var counterweight = Control.new()
		counterweight.custom_minimum_size = Vector2(shift * 2.0, 0)
		party_row.add_child(counterweight)

## The promoted card: big, gold-edged, with level, ATK, both gauges, and
## the minion's inked battle runes as chips.
func _make_active_card(index: int) -> PanelContainer:
	var member = party[index]
	var minion = MinionManager.find_minion_by_id(member["minion_id"])
	var downed = member["hp"] <= 0

	var card = PanelContainer.new()
	card.custom_minimum_size = Vector2(ACTIVE_W, 0)
	var style := StyleBoxFlat.new()
	style.bg_color = COL_CARD
	style.border_color = COL_GOLD
	style.set_border_width_all(2)
	style.set_corner_radius_all(8)
	style.content_margin_left = 12
	style.content_margin_right = 12
	style.content_margin_top = 9
	style.content_margin_bottom = 10
	card.add_theme_stylebox_override("panel", style)
	if downed:
		card.modulate.a = 0.55

	var col = VBoxContainer.new()
	col.add_theme_constant_override("separation", 5)
	card.add_child(col)

	var top = HBoxContainer.new()
	top.add_theme_constant_override("separation", 8)
	col.add_child(top)
	var initial = Label.new()
	initial.text = minion.name.left(1)
	initial.add_theme_font_size_override("font_size", 20)
	initial.add_theme_color_override("font_color", COL_VIOLET)
	top.add_child(initial)
	var name_lbl = Label.new()
	name_lbl.text = "%s — Lv %d" % [minion.name, MinionManager.get_level(minion.id)]
	name_lbl.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	name_lbl.text_overrun_behavior = TextServer.OVERRUN_TRIM_ELLIPSIS
	name_lbl.add_theme_font_size_override("font_size", 14)
	name_lbl.add_theme_color_override("font_color", COL_TEXT_HI)
	top.add_child(name_lbl)
	var stats = Label.new()
	stats.text = "%d/%d · ATK %.1f" % [member["hp"], member["max_hp"], MinionManager.get_atk(minion.id)]
	stats.add_theme_font_size_override("font_size", 12)
	stats.add_theme_color_override("font_color", COL_TEXT_LOW)
	top.add_child(stats)

	col.add_child(_make_bar(float(member["hp"]) / float(member["max_hp"]), _hp_color(member), 8))

	# The turn gauge, labelled so it reads as "when this fills, I act"
	var turn_row = HBoxContainer.new()
	turn_row.add_theme_constant_override("separation", 6)
	turn_row.tooltip_text = "Turn gauge — when it fills, %s takes its turn. Speed %.1f." \
		% [minion.name, minion.speed]
	col.add_child(turn_row)
	var turn_lbl = Label.new()
	var is_ready = waiting_for_command and index == acting_index and not downed
	turn_lbl.text = "TURN — READY" if is_ready else "TURN"
	turn_lbl.add_theme_font_size_override("font_size", 9)
	turn_lbl.add_theme_color_override("font_color", COL_GOLD if is_ready else COL_TEXT_GHOST)
	turn_row.add_child(turn_lbl)
	var charge_bar = _make_bar(member["charge"], COL_GOLD, 5)
	charge_bar.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	charge_bar.size_flags_vertical = Control.SIZE_SHRINK_CENTER
	charge_fills[index] = charge_bar.get_child(0)
	turn_row.add_child(charge_bar)

	var actions = HBoxContainer.new()
	actions.add_theme_constant_override("separation", 5)
	col.add_child(actions)
	if downed:
		var down = Label.new()
		down.text = "down"
		down.add_theme_font_size_override("font_size", 11)
		down.add_theme_color_override("font_color", COL_RUST)
		actions.add_child(down)
		return card
	if member["guarding"]:
		var guard = Label.new()
		guard.text = "🛡 guarding"
		guard.add_theme_font_size_override("font_size", 11)
		guard.add_theme_color_override("font_color", COL_GREEN)
		actions.add_child(guard)
	var any_active := false
	for ability in minion.abilities:
		if ability == null or ability.kind != MinionAbility.Kind.ACTIVE: continue
		if not MinionManager.has_ability(minion.id, ability.id): continue
		any_active = true
		actions.add_child(_make_rune_chip(index, minion, ability))
	if not any_active and not member["guarding"]:
		var ready = Label.new()
		ready.text = "ready — no battle runes inked" if waiting_for_command else "charging…"
		ready.add_theme_font_size_override("font_size", 11)
		ready.add_theme_color_override("font_color", COL_GOLD if waiting_for_command else COL_TEXT_GHOST)
		actions.add_child(ready)
	return card

func _make_rune_chip(member_idx: int, minion: Minion, ability: MinionAbility) -> Button:
	var spent = _active_used(minion.id, ability.id)
	var usable = waiting_for_command and not auto_mode and member_idx == acting_index and not spent

	var chip = Button.new()
	chip.text = ability.name + (" ✕" if spent else "")
	chip.custom_minimum_size = Vector2(0, 22)
	chip.disabled = not usable
	chip.add_theme_font_size_override("font_size", 10)
	var style := StyleBoxFlat.new()
	style.bg_color = COL_STRIP
	style.set_border_width_all(1)
	style.border_color = COL_VIOLET if usable else COL_EDGE
	style.set_corner_radius_all(4)
	style.content_margin_left = 8
	style.content_margin_right = 8
	chip.add_theme_stylebox_override("normal", style)
	chip.add_theme_stylebox_override("hover", style)
	chip.add_theme_stylebox_override("pressed", style)
	chip.add_theme_stylebox_override("disabled", style)
	chip.add_theme_stylebox_override("focus", StyleBoxEmpty.new())
	chip.add_theme_color_override("font_color", COL_VIOLET_TEXT if usable else COL_TEXT_GHOST)
	chip.add_theme_color_override("font_disabled_color", COL_TEXT_GHOST)
	chip.tooltip_text = "%s — hits %.0f%% harder, once per battle.%s" \
		% [ability.description, ACTIVE_RUNE_MULT * 100.0, " Already spent." if spent else ""]
	if usable:
		chip.pressed.connect(func(): _execute_active(member_idx, ability))
	return chip

## AB3's right zone: one bordered panel holding a compact row per squad
## member — name, wide HP bar, short charge bar.
func _make_squad_panel() -> PanelContainer:
	var panel = PanelContainer.new()
	panel.custom_minimum_size = Vector2(SQUAD_W, 0)
	var style := StyleBoxFlat.new()
	style.bg_color = COL_STRIP
	style.set_border_width_all(1)
	style.border_color = COL_EDGE
	style.set_corner_radius_all(8)
	style.content_margin_left = 12
	style.content_margin_right = 12
	style.content_margin_top = 8
	style.content_margin_bottom = 8
	panel.add_theme_stylebox_override("panel", style)

	var col = VBoxContainer.new()
	col.alignment = BoxContainer.ALIGNMENT_CENTER
	col.add_theme_constant_override("separation", 6)
	panel.add_child(col)

	for i in range(party.size()):
		if i == acting_index: continue
		col.add_child(_make_squad_row(i))
	return panel

func _make_squad_row(index: int) -> HBoxContainer:
	var member = party[index]
	var minion = MinionManager.find_minion_by_id(member["minion_id"])
	var downed = member["hp"] <= 0
	var reeling = not downed and float(member["hp"]) / float(member["max_hp"]) <= 0.2

	var row = HBoxContainer.new()
	row.add_theme_constant_override("separation", 7)
	row.tooltip_text = "%s — %d / %d HP%s" % [minion.name, member["hp"], member["max_hp"],
		", guarding" if member["guarding"] else ""]
	if downed:
		row.modulate.a = 0.55

	var name_lbl = Label.new()
	name_lbl.text = minion.name + (" 🛡" if member["guarding"] else "")
	name_lbl.custom_minimum_size = Vector2(76, 0)
	name_lbl.text_overrun_behavior = TextServer.OVERRUN_TRIM_ELLIPSIS
	name_lbl.add_theme_font_size_override("font_size", 11)
	name_lbl.add_theme_color_override("font_color",
		COL_RUST if reeling or downed else COL_TEXT_MID)
	row.add_child(name_lbl)

	var hp_bar = _make_bar(float(member["hp"]) / float(member["max_hp"]), _hp_color(member), 5)
	hp_bar.size_flags_horizontal = Control.SIZE_EXPAND_FILL
	hp_bar.size_flags_vertical = Control.SIZE_SHRINK_CENTER
	row.add_child(hp_bar)

	var charge = _make_bar(member["charge"], COL_CHARGE, 4)
	charge.custom_minimum_size = Vector2(34, 4)
	charge.size_flags_vertical = Control.SIZE_SHRINK_CENTER
	charge.tooltip_text = "Turn gauge — when it fills, %s takes its turn." % minion.name
	charge_fills[index] = charge.get_child(0)
	row.add_child(charge)
	return row

# --- Small pieces ---

func _hp_color(member: Dictionary) -> Color:
	var frac = float(member["hp"]) / float(member["max_hp"])
	if frac <= 0.2: return COL_RUST
	if frac <= 0.5: return COL_GOLD
	return COL_GREEN

## A flat track + fill bar (the theme's ProgressBar fights custom layouts).
## The fill panel is child 0, so callers can grab it for per-frame updates.
func _make_bar(fraction: float, color: Color, height: int) -> Panel:
	var track = Panel.new()
	track.custom_minimum_size = Vector2(0, height)
	var tstyle := StyleBoxFlat.new()
	tstyle.bg_color = COL_WELL
	tstyle.set_corner_radius_all(int(height / 2.0))
	track.add_theme_stylebox_override("panel", tstyle)

	var fill = Panel.new()
	fill.set_anchors_preset(Control.PRESET_FULL_RECT)
	fill.anchor_right = clampf(fraction, 0.0, 1.0)
	var fstyle := StyleBoxFlat.new()
	fstyle.bg_color = color
	fstyle.set_corner_radius_all(int(height / 2.0))
	fill.add_theme_stylebox_override("panel", fstyle)
	fill.visible = fraction > 0.001
	track.add_child(fill)
	return track

func _on_auto_toggled(pressed: bool) -> void:
	auto_mode = pressed
	# Flipping to auto releases any minion frozen mid-command.
	if auto_mode and waiting_for_command:
		waiting_for_command = false
	_refresh_all()
	_log("The dead take matters into their own hands." if auto_mode else "You take command once more.")

func _log(text: String) -> void:
	if log_label:
		log_label.text = text

func _clear(container: Node) -> void:
	for child in container.get_children():
		container.remove_child(child)
		child.queue_free()
