# =====================================================================
# The rising fan: root rune at the base, ability runes fanning upward,
# one arc per tier. Positions come from each ability's `tier` — nothing
# is hand-placed.
class SigilTree:
	extends Control

	signal rune_selected(ability_id: String)

	const ARC_STEP: float = 78.0
	const RUNE_R: float = 17.0
	const ROOT_R: float = 20.0
	const FAN_FROM_DEG: float = 38.0
	const FAN_TO_DEG: float = 142.0

	var minion: Minion = null
	var selected_id: String = ""
	var rune_centers: Dictionary = {}   # ability_id -> Vector2

	func setup(target: Minion, selected: String) -> void:
		minion = target
		selected_id = selected
		custom_minimum_size = Vector2(340, 270)
		resized.connect(_layout)
		_layout.call_deferred()

	func _root_pos() -> Vector2:
		return Vector2(size.x * 0.5, size.y - ROOT_R - 6.0)

	## Computes every rune's center and (re)builds the rune buttons.
	func _layout() -> void:
		for child in get_children():
			remove_child(child)
			child.queue_free()
		rune_centers.clear()
		if minion == null: return

		var tiers: Dictionary = {}
		for ability in minion.abilities:
			if ability == null: continue
			var t = maxi(ability.tier, 1)
			if not tiers.has(t): tiers[t] = []
			tiers[t].append(ability)

		var root = _root_pos()
		for t in tiers:
			var row: Array = tiers[t]
			for i in range(row.size()):
				var ability: MinionAbility = row[i]
				var span = FAN_TO_DEG - FAN_FROM_DEG
				var angle = deg_to_rad(FAN_FROM_DEG + span * (i + 1) / (row.size() + 1))
				var radius = ARC_STEP * t
				var center = root + Vector2(cos(angle) * radius, -sin(angle) * radius)
				rune_centers[ability.id] = center
				add_child(_make_rune(ability, center))
		queue_redraw()

	func _make_rune(ability: MinionAbility, center: Vector2) -> Button:
		var b = Button.new()
		b.custom_minimum_size = Vector2(RUNE_R * 2, RUNE_R * 2)
		b.position = center - Vector2(RUNE_R, RUNE_R)
		b.text = ability.name.left(1)
		b.add_theme_font_size_override("font_size", 13)
		b.tooltip_text = "%s — %s" % [ability.name, ability.description]

		var owned = MinionManager.has_ability(minion.id, ability.id)
		var can = MinionManager.can_unlock_ability(minion.id, ability.id)
		var style := StyleBoxFlat.new()
		style.set_corner_radius_all(int(RUNE_R))
		if owned:
			style.bg_color = Color("#d5c49b")
			style.border_color = Color("#6b5636")
			style.set_border_width_all(2)
			b.add_theme_color_override("font_color", Color("#2c2015"))
		elif can:
			style.bg_color = Color("#e8dcc0")
			style.border_color = Color("#6d2f28")
			style.set_border_width_all(2)
			b.add_theme_color_override("font_color", Color("#6d2f28"))
		else:
			style.bg_color = Color("#e2d4b0")
			style.border_color = Color("#a89162")
			style.set_border_width_all(1)
			b.add_theme_color_override("font_color", Color("#8a7550"))
		if ability.id == selected_id:
			style.border_color = Color("#c8a24d")
			style.set_border_width_all(3)
		var hover: StyleBoxFlat = style.duplicate()
		hover.border_color = Color("#c8a24d")
		b.add_theme_stylebox_override("normal", style)
		b.add_theme_stylebox_override("hover", hover)
		b.add_theme_stylebox_override("pressed", style)
		b.add_theme_stylebox_override("focus", StyleBoxEmpty.new())
		b.add_theme_color_override("font_hover_color", Color("#2c2015"))
		b.pressed.connect(func(): rune_selected.emit(ability.id))
		return b

	func _draw() -> void:
		if minion == null: return
		var root = _root_pos()

		# Faint tier arcs
		var max_tier := 1
		for ability in minion.abilities:
			if ability: max_tier = maxi(max_tier, ability.tier)
		for t in range(1, max_tier + 1):
			draw_arc(root, ARC_STEP * t, deg_to_rad(-FAN_TO_DEG), deg_to_rad(-FAN_FROM_DEG),
				40, Color("#c9b891", 0.7), 1.0, true)

		# Connectors: prereq rune (or the root) -> rune
		for ability in minion.abilities:
			if ability == null or not rune_centers.has(ability.id): continue
			var to: Vector2 = rune_centers[ability.id]
			var sources: Array = []
			if ability.prerequisites.is_empty():
				sources.append(root)
			else:
				for prereq in ability.prerequisites:
					sources.append(rune_centers.get(prereq, root))
			var owned = MinionManager.has_ability(minion.id, ability.id)
			var can = MinionManager.can_unlock_ability(minion.id, ability.id)
			for from in sources:
				var dir = (to - from).normalized()
				var a = from + dir * (ROOT_R if from == root else RUNE_R)
				var b = to - dir * RUNE_R
				if owned:
					draw_line(a, b, Color("#6b5636"), 1.6, true)
				elif can:
					draw_line(a, b, Color("#6d2f28"), 1.4, true)
				else:
					draw_dashed_line(a, b, Color("#a89162"), 1.2, 4.0)

		# The root rune: the minion itself
		draw_circle(root, ROOT_R, Color("#d5c49b"))
		draw_arc(root, ROOT_R, 0, TAU, 40, Color("#6b5636"), 2.0, true)
		var font = get_theme_default_font()
		var glyph = minion.name.left(1)
		var gsize = font.get_string_size(glyph, HORIZONTAL_ALIGNMENT_CENTER, -1, 15)
		draw_string(font, root + Vector2(-gsize.x * 0.5, gsize.y * 0.32), glyph,
			HORIZONTAL_ALIGNMENT_CENTER, -1, 15, Color("#2c2015"))
